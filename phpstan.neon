includes:
    - ../../vendor/glpi-project/phpstan-glpi/extension.neon

parameters:
    level: 0
    paths:
        - src
        - hook.php
        - setup.php
    scanDirectories:
        - ../../inc
        - ../../src
    excludePaths:
        - src/Cite.php

    bootstrapFiles:
        - ../../vendor/autoload.php