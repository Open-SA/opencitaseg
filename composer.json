{
  "name": "opensa/opencitaseg",
  "description": "Plugin para GLPI que permite citar seguimientos.",
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "glpi-project/tools": "^0.8",
    "squizlabs/php_codesniffer": "^4.0"
  },
  "config": {
    "optimize-autoloader": true,
    "platform": {
      "php": "7.4.0"
    },
    "sort-packages": true
  },
  "autoload": {
    "psr-4": {
      "GlpiPlugin\\Opencitaseg\\": [
        "src/",
        "inc/"
      ]
    }
  },
  "scripts": {
    "post-install-cmd": [
      "git config core.hooksPath .git-hooks",
      "chmod +x .git-hooks/pre-commit",
      "echo 'Git hooks configured \\n';"
    ],
    "post-update-cmd": [
      "git config core.hooksPath .git-hooks",
      "chmod +x .git-hooks/pre-commit",
      "echo 'Git hooks configured \\n';"
    ]
  }
}
